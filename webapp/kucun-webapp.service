[Unit]
Description=Kucun Inventory Webapp
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/kucun/webapp
Environment="PATH=/opt/kucun/webapp/venv/bin"
ExecStart=/opt/kucun/webapp/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8001
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
